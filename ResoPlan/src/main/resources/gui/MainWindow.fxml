<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="720.0" prefWidth="1280.0" stylesheets="@../style/style.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1"
	fx:controller="org.targol.resoplan.ui.MainWindowController">
	<children>
		<MenuBar VBox.vgrow="NEVER">
			<menus>
				<Menu mnemonicParsing="false" text="%MainWindow.mnu_proj">
					<items>
						<MenuItem mnemonicParsing="false" onAction="#newProject" text="%MainWindow.mnu_proj.itm_new" />
						<MenuItem mnemonicParsing="false" text="%MainWindow.mnu_proj.itm_open" />
						<MenuItem mnemonicParsing="false" disable="true" fx:id="mnuClose" onAction="#closeProject" text="%MainWindow.mnu_proj.itm_close" />
						<Menu fx:id="mnuRecentProjects" mnemonicParsing="false" text="%MainWindow.mnu_proj.itm_recent" />
						<SeparatorMenuItem mnemonicParsing="false" />
						<MenuItem mnemonicParsing="false" text="%MainWindow.mnu_proj.itm_saveas" />
						<SeparatorMenuItem mnemonicParsing="false" />
						<MenuItem mnemonicParsing="false" text="%MainWindow.mnu_proj.itm_import" />
						<MenuItem mnemonicParsing="false" text="%MainWindow.mnu_proj.itm_export" />
						<SeparatorMenuItem mnemonicParsing="false" />
						<MenuItem mnemonicParsing="false" onAction="#showPrefs" text="%MainWindow.mnu_proj.itm_prefs" />
						<SeparatorMenuItem mnemonicParsing="false" />
						<MenuItem mnemonicParsing="false" text="%MainWindow.mnu_proj.itm_quit" />
					</items>
				</Menu>
			</menus>
		</MenuBar>
		<BorderPane VBox.vgrow="ALWAYS" xmlns:fx="http://javafx.com/fxml">
			<center>
			</center>
			<top>
			</top>
			<center>
				<StackPane fx:id="contentPane" />
			</center>
		</BorderPane>
	</children>
</VBox>
