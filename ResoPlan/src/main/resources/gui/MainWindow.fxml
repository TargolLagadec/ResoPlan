<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.CheckMenuItem?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.SeparatorMenuItem?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="720.0" prefWidth="1280.0" stylesheets="@../style/style.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.targol.resoplan.ui.MainWindowController">
	<children>
		<MenuBar VBox.vgrow="NEVER">
			<menus>
				<Menu mnemonicParsing="false" text="%MainWindow.mnu_proj">
					<items>
						<MenuItem mnemonicParsing="false" onAction="#newProject" text="%MainWindow.mnu_proj.itm_new" />
						<MenuItem mnemonicParsing="false" text="%MainWindow.mnu_proj.itm_open" />
						<MenuItem fx:id="mnuClose" disable="true" mnemonicParsing="false" onAction="#closeProject" text="%MainWindow.mnu_proj.itm_close" />
						<Menu fx:id="mnuRecentProjects" mnemonicParsing="false" text="%MainWindow.mnu_proj.itm_recent" />
						<SeparatorMenuItem mnemonicParsing="false" />
						<MenuItem mnemonicParsing="false" onAction="#showPrefs" text="%MainWindow.mnu_proj.itm_prefs" />
						<SeparatorMenuItem mnemonicParsing="false" />
						<MenuItem mnemonicParsing="false" text="%MainWindow.mnu_proj.itm_quit" />
					</items>
				</Menu>
            <Menu mnemonicParsing="false" text="%MainWindow.mnu_aff">
               <items>
                  <MenuItem fx:id="mnuAjust" onAction="#displayAdjustPanel" disable="true" mnemonicParsing="false" text="%MainWindow.mnu_aff.itm_ajust" />
                  <MenuItem fx:id="mnuNetwork" onAction="#displayNetworksPanel" disable="true" mnemonicParsing="false" text="%MainWindow.mnu_aff.itm_network" />
                  <MenuItem fx:id="mnuDebit" onAction="#displayDebitPanel" disable="true" mnemonicParsing="false" text="%MainWindow.mnu_aff.itm_debit" />
               </items>
            </Menu>
			</menus>
		</MenuBar>
		<BorderPane VBox.vgrow="ALWAYS" xmlns:fx="http://javafx.com/fxml">
			<center>
			</center>
			<top>
			</top>
			<center>
				<StackPane fx:id="contentPane" />
			</center>
		</BorderPane>
	</children>
</VBox>
