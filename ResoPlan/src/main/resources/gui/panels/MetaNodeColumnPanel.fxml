<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<fx:root type="BorderPane" VBox.vgrow="ALWAYS" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1">
	<top>
		<TitledPane animated="false" collapsible="false" text="%MetaNodeColumnPanel.title"
			BorderPane.alignment="CENTER">
			<content>
				<GridPane BorderPane.alignment="CENTER">
					<Label text="%NodePropertiesPanel.posX" wrapText="true" GridPane.columnIndex="0" GridPane.rowIndex="0" />
					<TextField fx:id="posXTextField" disable="true" editable="false" GridPane.columnIndex="1"
						GridPane.rowIndex="0" />

					<Label text="%NodePropertiesPanel.posY" wrapText="true" GridPane.columnIndex="0" GridPane.rowIndex="1" />
					<TextField fx:id="posYTextField" disable="true" editable="false" GridPane.columnIndex="1"
						GridPane.rowIndex="1" />

					<columnConstraints>
						<ColumnConstraints  />
						<ColumnConstraints hgrow="ALWAYS" minWidth="10.0" prefWidth="100.0" />
					</columnConstraints>
					<rowConstraints>
						<RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
						<RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
					</rowConstraints>
				</GridPane>
			</content>
			<font>
				<Font size="18.0" />
			</font>
		</TitledPane>
	</top>
</fx:root>
