<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane VBox.vgrow="ALWAYS"
	xmlns:fx="http://javafx.com/fxml" xmlns="http://javafx.com/javafx/26"
	fx:controller="org.targol.resoplan.ui.panels.WelcomePanelController">
	<center>
		<VBox alignment="CENTER" styleClass="content">
			<Label alignment="CENTER" contentDisplay="CENTER"
				minHeight="150.0" styleClass="heading"
				text="%MainWindow.label.NoneOpened" textAlignment="CENTER">
				<font>
					<Font size="24.0" />
				</font>
			</Label>
			<Button mnemonicParsing="false" onAction="#onNewProjectClick"
				text="%Dialog.project.title.new">
				<font>
					<Font size="24.0" />
				</font>
			</Button>
		</VBox>
	</center>
	<bottom>
		<ListView fx:id="lstProjects" BorderPane.alignment="CENTER">
			<BorderPane.margin>
				<Insets bottom="50.0" left="50.0" right="50.0" top="50.0" />
			</BorderPane.margin>
		</ListView>
	</bottom>
</BorderPane>
